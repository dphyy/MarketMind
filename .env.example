# Copy to .env and fill in when you wire live sponsor APIs.
# Everything runs on seed data until these are set.

# Database (defaults match docker-compose.yml)
DB_URL=jdbc:postgresql://localhost:5432/marketmind
DB_USER=marketmind
DB_PASSWORD=marketmind

# Bright Data — competitor scraping
BRIGHTDATA_API_KEY=

# SenseNova U1 — visual signal extraction
SENSENOVA_API_KEY=
# SENSENOVA_BASE_URL=https://api.sensenova.cn/v1

# Kimi K2.6 — strategy reasoning + morning brief
# Confirm base-url + model from the hackathon Kimi docs (platform.kimi.ai)
KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.6

# TokenRouter — route Kimi calls through here for caching (drop-in base-url swap)
TOKENROUTER_API_KEY=
# TOKENROUTER_BASE_URL=

# Daytona — sandboxed execution of the action step
DAYTONA_API_KEY=
# DAYTONA_BASE_URL=

# Frontend origins allowed by CORS
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
